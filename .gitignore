# Visual Studio / .NET build artifacts and user-specific files
# See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore for reference

# User-specific files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
**/bin/
**/obj/
bin/
obj/

# NuGet
packages/
*.nupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Rider / VS Code
.idea/
.vscode/

# Logs and databases
*.log
*.vspscc
*.vssscc
*.cache
*.opendb

# Visual Studio profiler
*.psess
*.vsp
